"""
数据API服务配置文件
"""

# ============ MaxCompute 连接配置 ============
ODPS_ACCESS_ID = 'your_access_id'
ODPS_ACCESS_KEY = 'your_access_key'
ODPS_PROJECT = "cupshe_bigdata_ads"
ODPS_ENDPOINT = "https://service.eu-central-1.maxcompute.aliyun.com/api"

# ============ 数据API配置 ============
API_HOST = "0.0.0.0"
API_PORT = 5000
MAX_RESULT_ROWS = 1000        # 单次查询最大返回行数
SQL_DIR = "sql"               # SQL文件目录

# ============ API Key 认证配置 ============
# 调用数据接口时需要传入此密钥（Header: X-API-Key）
# 留空字符串 "" 表示不启用认证（本地开发用）
# 部署到公网时请务必设置一个强密码
API_KEY = "your-api-key-here"

# ============ AI 配置 ============
# 支持 OpenAI 兼容接口（OpenAI / Ollama / 其他）
LLM_API_BASE = "http://localhost:11434/v1"   # Ollama 本地地址
LLM_API_KEY = "ollama"                        # Ollama 不需要真实key
LLM_MODEL = "qwen2.5:7b"                     # 模型名称

# 如果用 OpenAI/Claude 等云端服务，修改上面的配置即可：
# LLM_API_BASE = "https://api.openai.com/v1"
# LLM_API_KEY = "sk-xxx"
# LLM_MODEL = "gpt-4o"
